# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env

# Node
node_modules/
.vite/

# Data artifacts (regenerable — do not commit large binaries)
data/raw/**/*.json
data/raw/**/*.csv
data/processed/*.parquet
data/processed/*.csv
db/*.duckdb
db/parquet/*.parquet
public/parquet/*.parquet

# Exception: verbatim external dataset (COMPASS-DOE/synthesis-networks, MIT).
# This is a citable third-party snapshot, not a regenerable artifact.
!data/raw/synthesis-networks/
!data/raw/synthesis-networks/**

# Large raster deliverables — too big for GitHub without LFS.
# Use `git add -f path.img` only after `git lfs install` has been run.
*.img
*.tif
*.tiff

# Geocoder cache
.geocode_cache.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# coastal-research harvest sandbox (resume cursors, ndjson caches, big raw GIS pulls)
data/raw/R11_coastal_ecosystems/_state/
data/raw/R11_coastal_ecosystems/_cache/
network_synth_spatial_analysis/coastal_protected/

# DuckDB write-ahead log sidecar (regenerated on every open).
db/*.duckdb.wal
db/*.duckdb.tmp
db/*.duckdb.bak

# Cowork-mode helper scripts emitted alongside batches of work. They are
# one-shot commit drivers, not source. Keep on disk for reference; don't
# track or push.
COMMIT_*.sh
